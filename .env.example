# Copy this file to `.env` and fill it in.  `.env` is gitignored — never commit it.
#
# ⚠️  Windows editors love to save CRLF line endings. A trailing \r on the API key
#     produces a 401 that looks EXACTLY like a wrong key. Save this file as LF.
#     Don't wrap values in quotes. No trailing spaces.

# Your Ask Sage account email.
ASKSAGE_EMAIL=

# Your Ask Sage API key.
ASKSAGE_API_KEY=

# Base URL of YOUR Ask Sage instance — no trailing slash.
# The commercial instance is https://api.asksage.ai
# Your government instance is a DIFFERENT host. Use the one your org approved.
ASKSAGE_BASE_URL=https://api.asksage.ai

# Exact model name. Run `npm run probe` to list what your account can actually see —
# do not guess this, gov instances use their own model strings.
ASKSAGE_MODEL=

# Optional. Port for the local server (127.0.0.1 only).
PORT=8765
