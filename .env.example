# Copy this file to `.env` and fill in the two settings below.
# `.env` is gitignored — never commit it.
#
# Then just run:  npm start
# It works out the rest and tells you if anything's missing.

# ─── Required ────────────────────────────────────────────────────────────

# Your Ask Sage API key.
ASKSAGE_API_KEY=

# Your Ask Sage host: the site you log into, with "chat." swapped for "api."
#   log into https://chat.asksage.ai      ->  https://api.asksage.ai
#   log into https://chat.your-gov.ai     ->  https://api.your-gov.ai
# Use your organisation's approved instance. No trailing slash.
ASKSAGE_BASE_URL=

# ─── Optional — leave blank; `npm start` will tell you if you need them ──

# The model to use. Leave blank the first time: `npm start` prints the list of
# models your account can actually see, then you paste one in here.
#
# ⚠️  CUI WARNING: the list mixes government and commercial endpoints.
#     Only "-gov" models are government. "-com" or no suffix = COMMERCIAL —
#     sending CUI there would be a spill. Note the commercial entries are often
#     the newer, more capable ones, which makes this an easy mistake.
#
#     For Claude Sonnet 4.5 on gov:  aws-bedrock-claude-45-sonnet-gov
ASKSAGE_MODEL=aws-bedrock-claude-45-sonnet-gov

# Usually NOT needed — on the NASA instance the API key authenticates on its own.
# Only set this if you get an authentication failure; Ask Sage documents an
# email + api_key -> token exchange that some instances require.
ASKSAGE_EMAIL=

# Port for the local server (127.0.0.1 only).
PORT=8765
