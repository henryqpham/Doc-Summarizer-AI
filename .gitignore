# secrets — NEVER commit
.env
.env.*
!.env.example

# the real output template (may be sensitive) — same pattern as .env:
# the tracked lib/instructions.example.txt is the placeholder fallback
lib/instructions.txt
# the live change-review prompt (may be sensitive) — tracked fallback is
# lib/instructions.changes.example.txt, same pattern as instructions.txt
lib/instructions.changes.txt
# backups and rework candidates of the sensitive template — never commit
lib/instructions.backup*.txt
lib/instructions.reworked.txt

# dependencies (there are none, but just in case)
node_modules/

# generated test fixture — recreated on demand by tools/make-test-pdf.mjs
test/fixtures/

# misc
.DS_Store
*.log
